    <item>
      <title>컴퓨터 구조 기초 정리</title>
      <link>https://IngakHwang.github.io/posts/%EC%BB%B4%ED%93%A8%ED%84%B0_%EA%B5%AC%EC%A1%B0_%EA%B8%B0%EC%B4%88_%EC%A0%95%EB%A6%AC/</link>
